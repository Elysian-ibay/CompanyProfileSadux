# ── Server ────────────────────────────────────────────────
PORT=5202
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
# DB_DIALECT: "postgres" (Supabase, default) or "mysql" (local XAMPP)
DB_DIALECT=postgres

# Option A (recommended for Supabase): single connection string / URI.
# Get it from Supabase > Project Settings > Database > Connection string > URI.
# Use the "Transaction pooler" URI (port 6543) for serverless / Vercel.
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Option B: individual values (used only if DATABASE_URL is not set).
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT_REF
DB_PASS=YOUR_SUPABASE_DB_PASSWORD
# DB_SSL is auto-enabled for postgres; set "true" to force it for other dialects.
# DB_SSL=true
# DB_POOL_MAX=3

# ── Auth ──────────────────────────────────────────────────
# Generate a strong secret, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# Leave empty for local dev to allow all.
CLIENT_ORIGIN=https://your-frontend.vercel.app

# ── Supabase Storage (file/image uploads) ─────────────────
# From Supabase > Project Settings > API.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SERVICE ROLE key — server-side only, NEVER expose to the frontend.
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Public bucket name for uploads (auto-created if missing).
SUPABASE_BUCKET=uploads
